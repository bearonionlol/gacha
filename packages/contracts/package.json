{
  "name": "@gacha/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "typecheck": "tsc --noEmit",
    "local": "ts-node scripts/local.ts",
    "rehearse:mainnet-fork": "ts-node scripts/mainnet-fork.ts",
    "validate:mainnet-manifest": "ts-node scripts/validate-release-manifest.ts",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network robinhoodTestnet",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network robinhoodMainnet",
    "seed:testnet": "hardhat run scripts/seed.ts --network robinhoodTestnet",
    "onboard-drop:testnet": "hardhat run scripts/onboard-drop.ts --network robinhoodTestnet",
    "onboard-pool:testnet": "hardhat run scripts/onboard-pool.ts --network robinhoodTestnet",
    "fulfill-pack-randomness:testnet": "hardhat run scripts/fulfill-pack-randomness.ts --network robinhoodTestnet",
    "smoke:testnet": "hardhat run scripts/smoke.ts --network robinhoodTestnet",
    "rehearse:testnet": "hardhat run scripts/rehearse.ts --network robinhoodTestnet"
  },
  "dependencies": {
    "@gacha/shared": "workspace:*",
    "@openzeppelin/contracts": "5.4.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "2.0.8",
    "@nomicfoundation/hardhat-ethers": "3.0.8",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "dotenv": "^16.4.7",
    "ethers": "6.15.0",
    "hardhat": "2.22.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
